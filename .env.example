# Flask
SECRET_KEY=change-this-secret
FLASK_DEBUG=1

# Data root (optional)
# ALPHAFIN_DB_ROOT=/absolute/path/to/your/db_dir

# Tushare
TUSHARE_TOKEN=your_tushare_token

# Qwen / DashScope
QWEN_API_KEY=your_qwen_api_key
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-vl-plus

# Kimi / Moonshot
MOONSHOT_API_KEY=your_moonshot_api_key
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
MOONSHOT_MODEL=kimi-k2.5

# AlphaTeam model (optional)
ALPHAFIN_TEAM_QWEN_MODEL=qwen3.5-plus
ALPHAFIN_TEAM_QWEN_FALLBACK_MODEL=qwen3.5-plus

# AlphaTeam per-agent keys (optional; fallback to QWEN_API_KEY)
# ALPHAFIN_TEAM_DIRECTOR_API_KEY=
# ALPHAFIN_TEAM_ANALYST_API_KEY=
# ALPHAFIN_TEAM_RISK_API_KEY=
# ALPHAFIN_TEAM_INTEL_API_KEY=
# ALPHAFIN_TEAM_QUANT_API_KEY=
# ALPHAFIN_TEAM_AUDITOR_API_KEY=
# ALPHAFIN_TEAM_RESTRUCTURING_API_KEY=
